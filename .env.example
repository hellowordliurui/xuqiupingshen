# SecondMe OAuth2（在 https://develop.second.me 创建应用后填写，真实值写在 .env.local）
SECONDME_CLIENT_ID=your_secondme_client_id
SECONDME_CLIENT_SECRET=your_secondme_client_secret
# 回调地址：本地用当前访问的 origin 自动拼，无需写死；线上必须和「用户实际访问的域名」完全一致
# 本地示例：http://localhost:3002/api/auth/callback 或 http://127.0.0.1:3002/api/auth/callback
# 线上（Vercel 等）必须在平台环境变量里设：SECONDME_REDIRECT_URI=https://你的域名/api/auth/callback
# 若用自定义域名，填自定义域名（如 https://myapp.com/api/auth/callback）；不要与访问域名混用 www/非 www
# Second Me 开发者后台（develop.second.me）应用里的「回调地址」也要填同一 URL（可配置多条）
SECONDME_REDIRECT_URI=http://localhost:3002/api/auth/callback

# SecondMe API 端点（一般无需修改）
SECONDME_API_BASE_URL=https://api.mindverse.com/gate/lab
SECONDME_OAUTH_URL=https://go.second.me/oauth/
SECONDME_TOKEN_ENDPOINT=https://api.mindverse.com/gate/lab/api/oauth/token/code
SECONDME_REFRESH_ENDPOINT=https://api.mindverse.com/gate/lab/api/oauth/token/refresh

# 数据库（复制到 .env.local，并替换 YOUR_SUPABASE_DB_PASSWORD）
# 密码在 Supabase Dashboard → Settings → Database 查看或重置
# Supabase 必须配两条：应用用 pooler:6543，Prisma db push 用直连 db.xxx.supabase.co:5432，否则会 P1000 认证失败
# DATABASE_URL="postgresql://postgres.项目ref:YOUR_SUPABASE_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DATABASE_DIRECT_URL="postgresql://postgres.项目ref:YOUR_SUPABASE_DB_PASSWORD@db.项目ref.supabase.co:5432/postgres"
# 本地 SQLite 可选（两条都指向同一文件即可）：
# DATABASE_URL="file:./dev.db"
# DATABASE_DIRECT_URL="file:./dev.db"

# MiniMax 文本模型（A2A 辩论、刘看山总结等，Second Me 不提供此类 LLM 能力需自接）
# 在 https://platform.minimax.io 注册，账户管理 > 接口密钥 创建 API Key
# 赛事可申领 $30 代金券：https://reconnect-hackathon.com/minimax
MINIMAX_API_KEY=
# 可选，默认 https://api.minimax.io
# MINIMAX_BASE_URL=https://api.minimax.io

# 知乎 OpenAPI（A2A 黑客松 - 全网可信搜等）
# 密钥申请：联系群内 @王佳蕴，提供知乎主页链接
ZHIHU_APP_KEY=
ZHIHU_APP_SECRET=
