# SecondMe OAuth2（在 https://develop.second.me 创建应用后填写）
SECONDME_CLIENT_ID=eb50309e-fa87-4272-9b80-201e4da7743e
SECONDME_CLIENT_SECRET=c99f561f6a7406fcad2b5106ca27f3fc94fff18be6d3fd36738a2af1010641ae
# 必须与 npm run dev 的端口一致（当前固定为 3002）
SECONDME_REDIRECT_URI=http://localhost:3002/api/auth/callback

# SecondMe API 端点（一般无需修改）
SECONDME_API_BASE_URL=https://api.mindverse.com/gate/lab
SECONDME_OAUTH_URL=https://go.second.me/oauth/
SECONDME_TOKEN_ENDPOINT=https://api.mindverse.com/gate/lab/api/oauth/token/code
SECONDME_REFRESH_ENDPOINT=https://api.mindverse.com/gate/lab/api/oauth/token/refresh

# 数据库（SQLite，本地开发可直接用 file:./dev.db）
DATABASE_URL="file:./dev.db"

# MiniMax 文本模型（A2A 辩论、刘看山总结等，Second Me 不提供此类 LLM 能力需自接）
# 在 https://platform.minimax.io 注册，账户管理 > 接口密钥 创建 API Key
# 赛事可申领 $30 代金券：https://reconnect-hackathon.com/minimax
MINIMAX_API_KEY=
# 可选，默认 https://api.minimax.io
# MINIMAX_BASE_URL=https://api.minimax.io

# 知乎 OpenAPI（A2A 黑客松 - 全网可信搜等）
# 密钥申请：联系群内 @王佳蕴，提供知乎主页链接
ZHIHU_APP_KEY=
ZHIHU_APP_SECRET=
