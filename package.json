{
  "name": "nitpicker-jury",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:turbo": "next dev --turbopack -p 3002 -H 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "node scripts/db-push.mjs",
    "seed:project": "node scripts/seed-one-project.mjs",
    "seed:messages": "node --env-file=.env.local scripts/seed-debate-messages.mjs",
    "fetch:flow": "node --env-file=.env.local scripts/fetch-debate-flow.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}
